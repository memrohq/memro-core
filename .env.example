# Database
DATABASE_URL=postgresql://memro:memro@postgres:5432/memro

# Vector Store
QDRANT_URL=http://qdrant:6333

# API Server
PORT=8081
RUST_LOG=info

# OpenAI API (for embeddings and Whisper)
OPENAI_API_KEY=your_openai_api_key_here

# File Storage
FILE_STORAGE_TYPE=local  # or s3
FILE_STORAGE_PATH=./data/files

# S3 Configuration (if using S3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=memro-files
# S3_REGION=us-east-1

# File Upload Limits
MAX_FILE_SIZE_MB=50
MAX_AUDIO_SIZE_MB=100
MAX_VIDEO_SIZE_MB=500

# Embedding Configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=100
AUTO_EMBED=true

# Optional: Custom domain for production
# DOMAIN=memro.yourdomain.com

# Optional: Enable HTTPS (production)
# ENABLE_HTTPS=true
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
